---
// HeroSection.astro - Home page hero banner
export interface Props {
  name: string;
  nameEn: string;
  tagline: string;
  photo: string;
  stats: Array<{ label: string; value: string }>;
}

const { name, nameEn, tagline, photo, stats } = Astro.props;
---

<section class="hero">
  <div class="hero-content">
    <div class="hero-text">
      <h1 class="hero-name">
        {name}
        <span class="hero-name-en">{nameEn}</span>
      </h1>
      <p class="hero-tagline">{tagline}</p>
      <div class="hero-stats">
        {stats.map(s => (
          <div class="hero-stat">
            <span class="hero-stat-value">{s.value}</span>
            <span class="hero-stat-label">{s.label}</span>
          </div>
        ))}
      </div>
    </div>
    <div class="hero-photo-wrapper">
      <img
        src={photo}
        alt={`${name} 个人照片`}
        class="hero-photo"
        width="200"
        height="200"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    background: linear-gradient(135deg, #1e3a5f 0%, #2563eb 50%, #1d4ed8 100%);
    color: white;
    padding: 3.5rem 0;
  }

  .hero-content {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    gap: 3rem;
  }

  .hero-text {
    flex: 1;
  }

  .hero-name {
    font-size: 2.5rem;
    color: white;
    margin-bottom: 0.25rem;
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .hero-name-en {
    font-size: 1rem;
    font-weight: 400;
    opacity: 0.8;
  }

  .hero-tagline {
    font-size: 1rem;
    color: rgba(255,255,255,0.85);
    line-height: 1.6;
    margin-bottom: 1.5rem;
    max-width: 600px;
  }

  .hero-stats {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .hero-stat {
    text-align: center;
  }
  .hero-stat-value {
    display: block;
    font-size: 1.5rem;
    font-weight: 700;
    color: white;
  }
  .hero-stat-label {
    display: block;
    font-size: 0.8125rem;
    color: rgba(255,255,255,0.7);
    margin-top: 0.125rem;
  }

  .hero-photo-wrapper {
    flex-shrink: 0;
  }

  .hero-photo {
    width: 160px;
    height: 160px;
    border-radius: 50%;
    object-fit: cover;
    object-position: center 15%;
    border: 3px solid rgba(255,255,255,0.3);
    box-shadow: 0 8px 32px rgba(0,0,0,0.15);
  }

  @media (max-width: 640px) {
    .hero {
      padding: 2rem 0;
    }
    .hero-content {
      flex-direction: column-reverse;
      text-align: center;
      gap: 1.25rem;
    }
    .hero-name {
      font-size: 1.5rem;
      justify-content: center;
    }
    .hero-name-en {
      font-size: 0.875rem;
    }
    .hero-stats {
      justify-content: center;
      gap: 1.25rem;
    }
    .hero-stat-value {
      font-size: 1.25rem;
    }
    .hero-tagline {
      max-width: 100%;
      font-size: 0.875rem;
    }
    .hero-photo {
      width: 100px;
      height: 100px;
      object-position: center 15%;
    }
  }
</style>
