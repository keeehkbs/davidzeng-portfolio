---
// Timeline.astro - Work experience vertical timeline
import '../styles/timeline.css';

export interface Job {
  company: string;
  role: string;
  period: string;
  content: string[];
  achievements: string[];
  cards: string[];
}

export interface Props {
  jobs: Job[];
}

const { jobs } = Astro.props;
---

<div class="timeline">
  {jobs.map(job => (
    <div class="timeline-item">
      <div class="timeline-header">
        <div>
          <div class="timeline-company">{job.company}</div>
          <div class="timeline-role">{job.role}</div>
        </div>
        <div class="timeline-period">{job.period}</div>
      </div>

      <div class="timeline-content">
        <ul>
          {job.content.map(item => <li>{item}</li>)}
        </ul>
      </div>

      {job.achievements.length > 0 && (
        <div class="timeline-achievements">
          <div class="timeline-achievements-label">🏆 工作成果</div>
          <ul>
            {job.achievements.map(a => <li>{a}</li>)}
          </ul>
        </div>
      )}

      {job.cards.length > 0 && (
        <div class="timeline-cards">
          {job.cards.map(card => (
            <img src={card} alt={`${job.company} 名片`} loading="lazy" decoding="async" />
          ))}
        </div>
      )}
    </div>
  ))}
</div>
