---
// reviews.astro - Contact page with form
import BaseLayout from '../layouts/BaseLayout.astro';
import { contactInfo } from '../data/reviews';
---

<BaseLayout title="联系我" description="联系 David Zeng - 请填写表单发送消息">
  <div class="page-header">
    <div class="container">
      <h1>📬 联系我</h1>
      <p>有任何问题或合作意向，欢迎通过以下表单与我联系</p>
    </div>
  </div>

  <!-- 联系表单 -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">✍️ 发送消息</h2>
      <p class="form-intro">请填写以下表单，我会尽快回复您。</p>
      <div class="card form-card">
        <form
          action="https://api.web3forms.com/submit"
          method="POST"
          class="contact-form"
        >
          <!-- 替换为你的 Web3Forms Access Key -->
          <input type="hidden" name="access_key" value="YOUR_ACCESS_KEY_HERE" />
          <input type="hidden" name="subject" value="来自 David Zeng 网站的新消息" />
          <input type="hidden" name="from_name" value="David Zeng 个人网站" />
          <input type="hidden" name="redirect" value="false" />

          <!-- Honeypot 反垃圾 -->
          <input type="checkbox" name="botcheck" class="hidden-check" style="display:none;" tabindex="-1" autocomplete="off" />

          <div class="form-group">
            <label for="name" class="form-label">姓名 <span class="required">*</span></label>
            <input
              type="text"
              id="name"
              name="name"
              class="form-input"
              placeholder="您的姓名"
              required
            />
          </div>

          <div class="form-group">
            <label for="email" class="form-label">邮箱 <span class="required">*</span></label>
            <input
              type="email"
              id="email"
              name="email"
              class="form-input"
              placeholder="your@email.com"
              required
            />
          </div>

          <div class="form-group">
            <label for="subject" class="form-label">主题</label>
            <input
              type="text"
              id="subject"
              name="custom_subject"
              class="form-input"
              placeholder="消息主题（可选）"
            />
          </div>

          <div class="form-group">
            <label for="message" class="form-label">消息内容 <span class="required">*</span></label>
            <textarea
              id="message"
              name="message"
              class="form-textarea"
              rows="6"
              placeholder="请输入您想说的内容…"
              required
            ></textarea>
          </div>

          <button type="submit" class="btn form-submit">
            ✉️ 发送消息
          </button>
        </form>
      </div>
    </div>
  </section>

  <!-- 其他联系方式 -->
  <section class="section" style="background: var(--color-surface);">
    <div class="container">
      <h2 class="section-title">📞 其他联系方式</h2>
      <p class="contact-note">{contactInfo.note}</p>
      <div class="contact-grid">
        <div class="card contact-card">
          <div class="contact-icon">📱</div>
          <div class="contact-label">手机</div>
          <div class="contact-value contact-value-private">
            <span>（站内联系）</span>
          </div>
        </div>
        <div class="card contact-card">
          <div class="contact-icon">✉️</div>
          <div class="contact-label">邮箱</div>
          <div class="contact-value contact-value-private">
            <span>（站内联系）</span>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .form-intro {
    color: var(--color-text-secondary);
    margin-bottom: 1.5rem;
  }

  .form-card {
    max-width: 680px;
    padding: 2rem;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .form-label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .required {
    color: #dc2626;
  }

  .form-input,
  .form-textarea {
    width: 100%;
    padding: 0.625rem 0.875rem;
    font-size: 0.9375rem;
    font-family: var(--font-sans);
    color: var(--color-text);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    transition: border-color 0.2s, box-shadow 0.2s;
    outline: none;
  }

  .form-input:focus,
  .form-textarea:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px var(--color-accent-light);
  }

  .form-input::placeholder,
  .form-textarea::placeholder {
    color: var(--color-text-muted);
  }

  .form-textarea {
    resize: vertical;
    min-height: 140px;
  }

  .form-submit {
    align-self: flex-start;
    font-size: 1rem;
    padding: 0.75rem 2rem;
    cursor: pointer;
  }

  .contact-note {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    margin-bottom: 1.25rem;
    text-align: center;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1rem;
  }

  .contact-card {
    text-align: center;
    padding: 2rem 1.5rem;
  }

  .contact-icon {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .contact-label {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin-bottom: 0.25rem;
  }

  .contact-value {
    font-size: 1.125rem;
    font-weight: 600;
  }

  .contact-value a {
    color: var(--color-accent);
    text-decoration: none;
  }

  .contact-value-private {
    color: var(--color-text-muted);
    font-size: 0.9375rem;
    font-weight: 400;
    font-style: italic;
  }

  @media (max-width: 640px) {
    .form-card {
      padding: 1.25rem;
    }
    .form-submit {
      width: 100%;
      justify-content: center;
    }
  }
</style>
