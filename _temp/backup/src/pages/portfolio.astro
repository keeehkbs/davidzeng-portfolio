---
// portfolio.astro - Portfolio page with masonry waterfall
import BaseLayout from '../layouts/BaseLayout.astro';
import MasonryGrid from '../components/MasonryGrid.astro';
import { portfolioCategories } from '../data/portfolio';
---

<BaseLayout title="个人作品" description="David Zeng 个人作品展示">
  <div class="page-header">
    <div class="container">
      <h1>🎨 个人作品</h1>
      <p>涵盖数据分析、应用开发、内容创作、平台搭建等领域</p>
    </div>
  </div>

  {portfolioCategories.map((category, i) => (
    <section class="section" style={i % 2 === 1 ? 'background: var(--color-surface);' : ''}>
      <div class="container">
        <h2 class="section-title">{category.name}</h2>
        <p class="category-desc">{category.description}</p>
        {category.images.length === 1 ? (
          <div class="single-image">
            <img
              src={category.images[0].src}
              alt={category.images[0].alt}
              loading="lazy"
              decoding="async"
              class="single-image-img"
            />
            <figcaption>{category.images[0].alt}</figcaption>
          </div>
        ) : (
          <MasonryGrid images={category.images} />
        )}
      </div>
    </section>
  ))}
</BaseLayout>

<style>
  .category-desc {
    color: var(--color-text-secondary);
    margin-bottom: 1.5rem;
    font-size: 0.9375rem;
  }

  .single-image {
    text-align: center;
  }
  .single-image-img {
    max-width: 100%;
    border-radius: var(--radius);
    box-shadow: var(--shadow-md);
    margin: 0 auto;
  }
  .single-image figcaption {
    margin-top: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 640px) {
    .category-desc {
      font-size: 0.875rem;
      margin-bottom: 1rem;
    }
  }
</style>
