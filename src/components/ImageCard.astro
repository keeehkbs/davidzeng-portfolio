---
// ImageCard.astro - Individual image in masonry grid
export interface Props {
  src: string;
  alt?: string;
  caption?: string;
  rotation?: number;
}

const { src, alt = '', caption, rotation = 0 } = Astro.props;

const style = rotation
  ? `transform: rotate(${rotation}deg);`
  : '';
---

<figure class="masonry-item">
  <img
    src={src}
    alt={alt}
    loading="lazy"
    decoding="async"
    width="600"
    height="400"
    style={style}
  />
  {caption && <figcaption>{caption}</figcaption>}
</figure>
