---
// PageNav.astro - Previous / Next page navigation at section bottom
import { pageOrder } from '../data/site-config';

export interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;
const idx = pageOrder.findIndex(p => p.path === currentPath);
const prev = idx > 0 ? pageOrder[idx - 1] : null;
const next = idx < pageOrder.length - 1 ? pageOrder[idx + 1] : null;

// Only render if there's at least one neighbor
if (!prev && !next) return;
---

<nav class="page-nav">
  <div class="page-nav-inner">
    {prev ? (
      <a href={prev.path} class="page-nav-link prev">
        <span class="page-nav-arrow">←</span>
        <span class="page-nav-hint">上一页</span>
        <span class="page-nav-label">{prev.label}</span>
      </a>
    ) : <span class="page-nav-spacer" />}

    {next ? (
      <a href={next.path} class="page-nav-link next">
        <span class="page-nav-hint">下一页</span>
        <span class="page-nav-label">{next.label}</span>
        <span class="page-nav-arrow">→</span>
      </a>
    ) : <span class="page-nav-spacer" />}
  </div>
</nav>

<style>
  .page-nav {
    padding: 1.5rem 0 0.5rem;
  }
  .page-nav-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }
  .page-nav-spacer {
    flex: 1;
  }
  .page-nav-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1rem;
    border-radius: var(--radius);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    text-decoration: none;
    transition: all 0.2s;
  }
  .page-nav-link:hover {
    border-color: var(--color-accent);
    box-shadow: var(--shadow-md);
  }
  .page-nav-link.prev {
    margin-right: auto;
  }
  .page-nav-link.next {
    margin-left: auto;
    text-align: right;
  }
  .page-nav-arrow {
    font-size: 1.125rem;
    color: var(--color-accent);
    transition: transform 0.2s;
  }
  .page-nav-link:hover .page-nav-arrow {
    transform: translateX(3px);
  }
  .page-nav-link.prev:hover .page-nav-arrow {
    transform: translateX(-3px);
  }
  .page-nav-hint {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    display: block;
    line-height: 1.2;
  }
  .page-nav-label {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.2;
  }
  .page-nav-link .page-nav-hint,
  .page-nav-link .page-nav-label {
    display: block;
  }

  @media (max-width: 480px) {
    .page-nav-link {
      padding: 0.5rem 0.75rem;
      gap: 0.375rem;
    }
    .page-nav-label {
      font-size: 0.8125rem;
    }
    .page-nav-hint {
      font-size: 0.6875rem;
    }
  }
</style>
