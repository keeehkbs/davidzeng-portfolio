---
// CapabilitySection.astro - Always-open capability section (no dropdown)
export interface Props {
  category: string;
  items: string[];
  images?: string[];
}

const { category, items, images = [] } = Astro.props;
---

<div class="capability-section">
  <h3 class="capability-title">{category}</h3>
  <ul class="capability-list">
    {items.map(item => <li>{item}</li>)}
  </ul>
  {images.length > 0 && (
    <div class="capability-images">
      {images.map(img => (
        <img src={img} alt={category} loading="lazy" decoding="async" />
      ))}
    </div>
  )}
</div>

<style>
  .capability-section {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1.25rem;
    margin-bottom: 0.75rem;
  }
  .capability-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.625rem;
  }
  .capability-list {
    list-style: none;
    padding-left: 0;
    margin-bottom: 0;
  }
  .capability-list li {
    position: relative;
    padding-left: 1.25rem;
    margin-bottom: 0.375rem;
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }
  .capability-list li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-size: 0.75rem;
    top: 0.15rem;
  }
  .capability-images {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 0.875rem;
    padding-top: 0.875rem;
    border-top: 1px dashed var(--color-border);
  }
  .capability-images img {
    max-height: 200px;
    width: auto;
    border-radius: 0.375rem;
    border: 1px solid var(--color-border);
    cursor: pointer;
    transition: transform 0.2s;
  }
  .capability-images img:hover {
    transform: scale(1.02);
  }

  @media (max-width: 640px) {
    .capability-section {
      padding: 1rem;
    }
    .capability-images img {
      max-height: 140px;
    }
  }
</style>
