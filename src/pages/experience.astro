---
// experience.astro - Work Experience page
import BaseLayout from '../layouts/BaseLayout.astro';
import Timeline from '../components/Timeline.astro';
import { workExperiences, otherProjects, vipPhotos, memberServiceImages } from '../data/experience';
---

<BaseLayout title="工作经历" description="David Zeng 24年工作经历">
  <div class="page-header">
    <div class="container">
      <h1>💼 工作经历</h1>
      <p>24年外资企业及商协会工作经验</p>
    </div>
  </div>

  <!-- 工作经历时间线 -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">📋 职业历程</h2>
      <Timeline jobs={workExperiences} />
    </div>
  </section>

  <!-- VIP合影 -->
  <section class="section" style="background: var(--color-surface);">
    <div class="container">
      <h2 class="section-title">🤝 VIP合影</h2>
      <p class="section-desc">与粤港工商界代表人物的合影留念</p>
      <div class="photo-grid">
        {vipPhotos.map(photo => (
          <figure class="photo-item">
            <img
              src={photo.src}
              alt={photo.alt}
              loading="lazy"
              decoding="async"
            />
            <figcaption>{photo.caption}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- 会员服务 -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">🏢 会员服务</h2>
      <p class="section-desc">为会员企业提供多样化服务与活动组织</p>
      <div class="photo-grid">
        {memberServiceImages.map(photo => (
          <figure class="photo-item">
            <img
              src={photo.src}
              alt={photo.alt}
              loading="lazy"
              decoding="async"
            />
            <figcaption>{photo.caption}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- 其他项目 -->
  <section class="section" style="background: var(--color-surface);">
    <div class="container">
      <h2 class="section-title">📌 其他项目经历</h2>
      <div class="card">
        <ul class="project-list">
          {otherProjects.map(p => <li>{p}</li>)}
        </ul>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  .project-list {
    list-style: none;
    padding-left: 0;
    margin-bottom: 0;
  }
  .project-list li {
    padding-left: 1.5rem;
    position: relative;
    margin-bottom: 0.5rem;
    font-size: 0.9375rem;
  }
  .project-list li::before {
    content: '✦';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-size: 0.75rem;
    top: 0.125rem;
  }

  .section-desc {
    color: var(--color-text-secondary);
    font-size: 0.9375rem;
    margin-bottom: 1.25rem;
  }

  .photo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 0.75rem;
  }

  .photo-item {
    background: var(--color-bg);
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--color-border);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .photo-item:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .photo-item img {
    width: 100%;
    height: 180px;
    object-fit: cover;
    display: block;
    image-orientation: from-image;
  }

  .photo-item figcaption {
    padding: 0.5rem 0.625rem;
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    text-align: center;
    line-height: 1.3;
  }

  @media (max-width: 640px) {
    .photo-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.5rem;
    }
    .photo-item img {
      height: 140px;
    }
  }

  @media (max-width: 400px) {
    .photo-grid {
      grid-template-columns: 1fr 1fr;
    }
    .photo-item img {
      height: 120px;
    }
  }
</style>
