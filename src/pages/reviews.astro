---
// reviews.astro - Reviews & Contact page
import BaseLayout from '../layouts/BaseLayout.astro';
import { reviews, contactInfo } from '../data/reviews';
---

<BaseLayout title="评价联系" description="领导评价与联系方式">
  <div class="page-header">
    <div class="container">
      <h1>📬 评价 & 联系</h1>
      <p>来自领导的工作评价，以及联系方式</p>
    </div>
  </div>

  <!-- 领导评价 -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">🌟 领导评价</h2>
      <div class="reviews-grid">
        {reviews.map(review => (
          <div class="card review-card">
            <img
              src={review.image}
              alt={review.description}
              loading="lazy"
              decoding="async"
              class="review-image"
            />
            <div class="review-body">
              <h3 class="review-name">{review.name}</h3>
              <p class="review-desc">{review.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 联系方式 -->
  <section class="section" style="background: var(--color-surface);">
    <div class="container">
      <h2 class="section-title">📞 联系方式</h2>
      <p class="contact-note">{contactInfo.note}</p>
      <div class="contact-grid">
        <div class="card contact-card">
          <div class="contact-icon">📱</div>
          <div class="contact-label">手机</div>
          <div class="contact-value contact-value-private">
            <span>（站内联系）</span>
          </div>
        </div>
        <div class="card contact-card">
          <div class="contact-icon">✉️</div>
          <div class="contact-label">邮箱</div>
          <div class="contact-value contact-value-private">
            <span>（站内联系）</span>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .reviews-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    max-width: 800px;
  }
  .review-card {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }
  .review-image {
    width: 120px;
    height: auto;
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
    flex-shrink: 0;
  }
  .review-body {
    flex: 1;
  }
  .review-name {
    font-size: 1.125rem;
    margin-bottom: 0.375rem;
  }
  .review-desc {
    color: var(--color-text-secondary);
    margin-bottom: 0;
  }

  .contact-note {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    margin-bottom: 1.25rem;
    text-align: center;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1rem;
  }
  .contact-card {
    text-align: center;
    padding: 2rem 1.5rem;
  }
  .contact-icon {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }
  .contact-label {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    margin-bottom: 0.25rem;
  }
  .contact-value {
    font-size: 1.125rem;
    font-weight: 600;
  }
  .contact-value a {
    color: var(--color-accent);
    text-decoration: none;
  }
  .contact-value-private {
    color: var(--color-text-muted);
    font-size: 0.9375rem;
    font-weight: 400;
    font-style: italic;
  }

  @media (max-width: 640px) {
    .review-card {
      flex-direction: column;
    }
    .review-image {
      width: 100%;
      max-width: 300px;
    }
  }
</style>
